# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=liabot
PG_USER=postgres
PG_PASSWORD=ditt-lösenord-här

# Ollama
# llama3.2   = snabb, bra för de flesta datorer (rekommenderas)
# llama3.1:8b = bättre kvalitet, kräver mer RAM/GPU
# mistral    = bra alternativ
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Sökord (kommaseparerat) — genereras automatiskt via dashboardet
SEARCH_KEYWORDS=

# API-server
API_HOST=0.0.0.0
API_PORT=8002
